# Where each "Join Pixie" waitlist lead is emailed (via FormSubmit — no API key).
# Optional: falls back to bytesuite@bytesplatform.com if unset.
# ONE-TIME: the first lead to a new address triggers a FormSubmit confirmation
# email — click its activation link once, then all future leads deliver.
WAITLIST_LEAD_EMAIL=bytesuite@bytesplatform.com

# ── Supabase Auth (dashboard login/register) ────────────────────────────────
# Get these from your Supabase project → Settings → API. The auth middleware is
# a no-op until both are set, so the marketing site keeps working without them.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# ── Prisma / Supabase Postgres (Pixie Lab app tables) ───────────────────────
# From Supabase → Project Settings → Database → Connection string (URI).
# DATABASE_URL uses the transaction pooler (port 6543); DIRECT_URL the session
# pooler (port 5432, used for migrations). Never commit real values.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@<pooler-host>:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@<pooler-host>:5432/postgres"

# ── Stripe billing ──────────────────────────────────────────────────────────
# From the Stripe dashboard. Webhook secret from `stripe listen` or the endpoint.
# Price IDs are the monthly recurring prices for each plan.
STRIPE_SECRET_KEY=sk_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_BUSINESS_MONTHLY=price_...
STRIPE_PRICE_AGENCY_MONTHLY=price_...
