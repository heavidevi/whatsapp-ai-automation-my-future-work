// Pixie SEO — additive Prisma models for the SEO service.
//
// ADDITIVE ONLY: this is a NEW schema file. It does not modify, rename, or
// remove any existing model, field, or relation. No migration has been run.
// Every model is tenant-scoped (tenantId) per the multi-tenant rule.
//
// NOTE on usage: the Pixie backend is Python/FastAPI, while Prisma is a JS/TS
// ORM. Consuming these models from Python requires either prisma-client-py or
// direct Postgres access (supabase-py / asyncpg) — both NEW dependencies that
// need approval. Until that decision, the API persists through the in-memory
// repository seam in backend/seo/repository.py, which mirrors these shapes.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SeoMode {
  PIXIE
  EXTERNAL
  BOTH
}

enum SeoReportStatus {
  PENDING
  COMPLETE
  FAILED
}

enum SeoSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  INFO
}

enum SeoCheckStatus {
  PASS
  FAIL
  WARN
  NOT_APPLICABLE
}

model SeoReport {
  id             String          @id @default(cuid())
  tenantId       String
  url            String          @default("")
  mode           SeoMode         @default(BOTH)
  status         SeoReportStatus @default(COMPLETE)
  score          Int             @default(0)
  scoreDetails   Json?
  idempotencyKey String?
  issues         SeoIssue[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId])
  @@index([tenantId, url])
}

model SeoScore {
  id        String   @id @default(cuid())
  tenantId  String
  reportId  String?
  url       String   @default("")
  score     Int      @default(0)
  details   Json?
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, url])
}

model SeoIssue {
  id             String         @id @default(cuid())
  tenantId       String
  reportId       String
  report         SeoReport      @relation(fields: [reportId], references: [id], onDelete: Cascade)
  checkId        String
  category       String
  severity       SeoSeverity    @default(INFO)
  status         SeoCheckStatus @default(WARN)
  title          String
  description    String         @default("")
  recommendation String         @default("")
  weight         Int            @default(0)
  evidence       Json?
  createdAt      DateTime       @default(now())

  @@index([tenantId])
  @@index([reportId])
}

model TrackedKeyword {
  id             String               @id @default(cuid())
  tenantId       String
  keyword        String
  url            String
  country        String?
  device         String?
  targetPosition Int?
  snapshots      SeoKeywordSnapshot[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@unique([tenantId, keyword, url])
  @@index([tenantId])
}

model SeoKeywordSnapshot {
  id               String         @id @default(cuid())
  tenantId         String
  trackedKeywordId String
  trackedKeyword   TrackedKeyword @relation(fields: [trackedKeywordId], references: [id], onDelete: Cascade)
  keyword          String
  url              String         @default("")
  position         Int?
  provider         String         @default("mock")
  createdAt        DateTime       @default(now())

  @@index([tenantId])
  @@index([tenantId, trackedKeywordId])
}

model SeoCompetitorReport {
  id            String   @id @default(cuid())
  tenantId      String
  baseUrl       String
  competitorUrl String
  scoreGap      Int?
  details       Json?
  createdAt     DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, baseUrl])
}

// ─────────────────────────────────────────────────────────────────────────────
// Pixie Marketing — additive Prisma models for the Marketing AI Agent.
//
// ADDITIVE ONLY: these are NEW models. They do not modify, rename, or remove any
// existing model, field, or relation. NO migration has been run. Every model is
// tenant-scoped (tenantId) per the multi-tenant rule.
//
// Usage note (same as the SEO models above): the backend is Python/FastAPI while
// Prisma is a JS/TS ORM. Until prisma-client-py / direct Postgres access is
// approved, the marketing API persists through the in-memory repository seam in
// backend/marketing/profile/repository.py, which mirrors these shapes. The full
// model set (campaigns, content, analytics, etc.) lands additively in its wave;
// Wave 1 seeds only the profile + industry preset.
// ─────────────────────────────────────────────────────────────────────────────

model MarketingProfile {
  id                String   @id @default(cuid())
  tenantId          String
  businessName      String
  industry          String   @default("generic")
  businessType      String   @default("")
  location          String   @default("")
  targetAudience    String   @default("")
  painPoints        Json?
  products          Json?
  pricing           String   @default("")
  brandTone         String   @default("")
  brandPersonality  String   @default("")
  usp               String   @default("")
  competitors       Json?
  platformsUsed     Json?
  monthlyGoal       String   @default("")
  budgetRange       String   @default("")
  primaryCta        String   @default("")
  websiteUrl        String   @default("")
  landingUrl        String   @default("")
  bookingUrl        String   @default("")
  contact           String   @default("")
  funnelStage       String   @default("awareness")
  contentStyle      String   @default("")
  restrictedClaims  Json?
  complianceNotes   String   @default("")
  language          String   @default("en")
  approvalRequired  Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([tenantId, businessName])
  @@index([tenantId])
  @@index([tenantId, industry])
}

model MarketingIndustryPreset {
  id                String   @id @default(cuid())
  industry          String   @unique
  displayName       String
  painPoints        Json?
  bestCampaignTypes Json?
  contentFormats    Json?
  commonOffers      Json?
  objectionHandling Json?
  platforms         Json?
  contentPillars    Json?
  seasonalLocalIdeas Json?
  leadMagnets       Json?
  ctaExamples       Json?
  complianceWarnings Json?
  thingsToAvoid     Json?
  highRisk          Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([industry])
}

// Wave 2 marketing models — still ADDITIVE, still NO migration run. Tenant-scoped.
// JSON columns hold the structured lists the in-memory repository round-trips
// today (schedule, hashtags, etc.); the durable layer maps 1:1 to these.

model MarketingCampaign {
  id              String   @id @default(cuid())
  tenantId        String
  name            String
  goal            String   @default("")
  campaignType    String   @default("brand_awareness")
  audience        String   @default("")
  platforms       Json?
  formats         Json?
  messagingAngle  String   @default("")
  hooks           Json?
  cta             String   @default("")
  schedule        Json?
  requiredAssets  Json?
  approvalStatus  String   @default("needs_review")
  startDate       String?
  endDate         String?
  kpiTargets      Json?
  risks           Json?
  complianceNotes Json?
  followUp        String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, approvalStatus])
}

model MarketingContentItem {
  id             String   @id @default(cuid())
  tenantId       String
  campaignId     String?
  platform       String   @default("instagram")
  contentType    String   @default("post")
  hook           String   @default("")
  mainCopy       String   @default("")
  caption        String   @default("")
  script         String   @default("")
  visualDirection String  @default("")
  shotList       Json?
  carouselSlides Json?
  cta            String   @default("")
  hashtags       Json?
  tone           String   @default("")
  targetAudience String   @default("")
  approvalStatus String   @default("needs_review")
  riskScore      Int      @default(0)
  createdByAgent String   @default("content_factory")
  version        Int      @default(1)
  scheduledTime  String?
  notes          String   @default("")
  createdAt      DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, campaignId])
}

model MarketingCreativeBrief {
  id            String   @id @default(cuid())
  tenantId      String
  contentRefId  String?
  platform      String   @default("instagram")
  videoFormat   String   @default("explainer")
  visualConcept String   @default("")
  sceneDirection Json?
  camera        String   @default("")
  mood          String   @default("")
  lighting      String   @default("")
  colors        Json?
  characters    Json?
  props         Json?
  background    String   @default("")
  onScreenText  Json?
  voiceover     String   @default("")
  music         String   @default("")
  editingPace   String   @default("")
  aspectRatio   String   @default("9:16")
  durationSeconds Int    @default(30)
  hookFrame     String   @default("")
  endingFrame   String   @default("")
  ctaFrame      String   @default("")
  assetChecklist Json?
  createdAt     DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, contentRefId])
}

model MarketingPlatformConnection {
  id           String   @id @default(cuid())
  tenantId     String
  platform     String
  supportLevel String   @default("future_placeholder")
  dryRun       Boolean  @default(true)
  connected    Boolean  @default(false)
  accountRef   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([tenantId, platform])
  @@index([tenantId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Pixie Content Creator — additive Prisma models for the AI Content Creator.
//
// ADDITIVE ONLY: these are NEW models. They do not modify, rename, or remove any
// existing model, field, or relation. NO migration has been run. Every model is
// tenant-scoped (tenantId) per the multi-tenant rule.
//
// Usage note (same as the SEO + Marketing models above): the backend is
// Python/FastAPI while Prisma is a JS/TS ORM. Until prisma-client-py / direct
// Postgres access is approved, the content-creator service persists through the
// in-memory repository seam (mirrors these shapes). Provider tokens are NEVER
// stored here in cleartext — only a non-secret accountRef placeholder.
// ─────────────────────────────────────────────────────────────────────────────

enum CcProviderMode {
  user_account
  pixie_account
}

enum CcApprovalStatus {
  pending
  approved
  rejected
  needs_changes
}

enum CcIdentitySource {
  reference_image
  generated_character
}

enum CcJobStatus {
  queued
  running
  done
  failed
  skipped
}

enum CcVideoStatus {
  pending
  generating
  ready
  failed
  mock
}

enum CcPostStatus {
  scheduled
  dry_run
  posted
  failed
}

enum CcQualityStatus {
  pass
  fail
  needs_retry
  manual_review
}

enum CcPlatformType {
  meta
  instagram
  tiktok
  youtube
  linkedin
  x
}

model CreatorProfile {
  id               String   @id @default(cuid())
  tenantId         String
  businessName     String
  businessType     String   @default("")
  productOrService String   @default("")
  targetAudience   String   @default("")
  niche            String   @default("")
  contentGoal      String   @default("")
  brandTone        String   @default("")
  language         String   @default("en")
  sellingPoints    Json?
  competitors      Json?
  ctaStyle         String   @default("")
  complianceNotes  String   @default("")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([tenantId, businessName])
  @@index([tenantId])
}

model InfluencerIdentity {
  id              String           @id @default(cuid())
  tenantId        String
  source          CcIdentitySource
  active          Boolean          @default(true)
  locked          Boolean          @default(true)
  referenceRef    String           @default("")
  characteristics Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([tenantId])
  @@index([tenantId, active])
}

model ProviderConnection {
  id                    String         @id @default(cuid())
  tenantId              String
  mode                  CcProviderMode @default(pixie_account)
  connectionType        String         @default("mock")
  connected             Boolean        @default(false)
  accountRef            String         @default("")
  estimatedCredits      Int            @default(0)
  estimatedProviderCost Float          @default(0)
  pixieMarkup           Float          @default(0)
  finalPrice            Float          @default(0)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  @@unique([tenantId, mode])
  @@index([tenantId])
}

model Trend {
  id        String   @id @default(cuid())
  tenantId  String
  source    String
  topic     String
  raw       Json?
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, source])
}

model Idea {
  id             String           @id @default(cuid())
  tenantId       String
  title          String
  angle          String           @default("")
  hook           String           @default("")
  source         String           @default("mock")
  approvalStatus CcApprovalStatus @default(pending)
  createdAt      DateTime         @default(now())

  @@index([tenantId])
  @@index([tenantId, approvalStatus])
}

model IdeaScore {
  id        String   @id @default(cuid())
  tenantId  String
  ideaId    String
  score     Int      @default(0)
  reasons   Json?
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, ideaId])
}

model Script {
  id             String           @id @default(cuid())
  tenantId       String
  ideaRef        String           @default("")
  hook           String           @default("")
  body           String           @default("")
  cta            String           @default("")
  wordCount      Int              @default(0)
  approxSeconds  Int              @default(15)
  approvalStatus CcApprovalStatus @default(pending)
  createdAt      DateTime         @default(now())

  @@index([tenantId])
  @@index([tenantId, approvalStatus])
}

model CostEstimate {
  id                    String         @id @default(cuid())
  tenantId              String
  scriptRef             String         @default("")
  providerMode          CcProviderMode @default(pixie_account)
  model                 String         @default("")
  estimatedCredits      Int            @default(0)
  estimatedProviderCost Float          @default(0)
  pixieMarkup           Float          @default(0)
  finalUserPrice        Float          @default(0)
  durationSeconds       Int            @default(15)
  retryBudget           Int            @default(2)
  createdAt             DateTime       @default(now())

  @@index([tenantId])
}

model Video {
  id            String        @id @default(cuid())
  tenantId      String
  scriptRef     String        @default("")
  status        CcVideoStatus @default(mock)
  assetRef      String        @default("")
  previewRef    String        @default("")
  identityRef   String        @default("")
  aspectRatio   String        @default("9:16")
  durationSeconds Int         @default(15)
  model         String        @default("")
  promptVersion String        @default("")
  createdAt     DateTime      @default(now())

  @@index([tenantId])
  @@index([tenantId, status])
}

model QualityCheck {
  id                 String          @id @default(cuid())
  tenantId           String
  videoRef           String          @default("")
  status             CcQualityStatus @default(pass)
  deterministicFlags Json?
  llmFlags           Json?
  retryCount         Int             @default(0)
  createdAt          DateTime        @default(now())

  @@index([tenantId])
  @@index([tenantId, videoRef])
}

model Post {
  id            String       @id @default(cuid())
  tenantId      String
  videoRef      String        @default("")
  platform      CcPlatformType @default(meta)
  status        CcPostStatus  @default(dry_run)
  scheduledTime String        @default("")
  dryRun        Boolean       @default(true)
  externalRef   String        @default("")
  createdAt     DateTime      @default(now())

  @@index([tenantId])
  @@index([tenantId, status])
}

model Metric {
  id             String   @id @default(cuid())
  tenantId       String
  postRef        String   @default("")
  views          Int      @default(0)
  likes          Int      @default(0)
  comments       Int      @default(0)
  shares         Int      @default(0)
  saves          Int      @default(0)
  watchTime      Float    @default(0)
  completionRate Float    @default(0)
  clicks         Int      @default(0)
  follows        Int      @default(0)
  leads          Int      @default(0)
  createdAt      DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, postRef])
}

model Learning {
  id        String   @id @default(cuid())
  tenantId  String
  samples   Int      @default(0)
  insights  Json?
  nextFocus String   @default("")
  createdAt DateTime @default(now())

  @@index([tenantId])
}

model ApprovalRecord {
  id        String           @id @default(cuid())
  tenantId  String
  gate      String
  targetRef String           @default("")
  status    CcApprovalStatus @default(pending)
  note      String           @default("")
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([tenantId])
  @@index([tenantId, gate])
}

model AgentLog {
  id            String      @id @default(cuid())
  tenantId      String
  stage         String
  status        CcJobStatus @default(done)
  inputRef      String      @default("")
  outputRef     String      @default("")
  model         String      @default("")
  promptVersion String      @default("")
  estimatedCost Float       @default(0)
  actualCost    Float       @default(0)
  latencyMs     Int         @default(0)
  retryCount    Int         @default(0)
  error         String      @default("")
  createdAt     DateTime    @default(now())

  @@index([tenantId])
  @@index([tenantId, stage])
}

// ─────────────────────────────────────────────────────────────────────────────
// Pixie Channels — additive Prisma models for the generic Channels layer.
//
// ADDITIVE ONLY: NEW models, no existing model changed/renamed/removed. NO
// migration run. Every model tenant-scoped. Secrets are NEVER stored here — only
// an opaque `credentialsRef` into the token vault; `mode`/`enabled` gate go-live.
// Until prisma-client-py / direct Postgres is approved, the Channels layer
// persists through the in-memory seam in backend/channels/store.py (same shapes).
// ─────────────────────────────────────────────────────────────────────────────

model ChannelConnection {
  id              String   @id @default(cuid())
  tenantId        String
  channel         String
  enabled         Boolean  @default(false)
  mode            String   @default("mock")   // mock | live
  supportLevel    String   @default("future_placeholder")
  credentialsRef  String?                       // opaque token-vault ref, never plaintext
  credentialsPresent Json?                      // booleans only — which cred keys exist
  requirementsMet Boolean  @default(false)
  missing         Json?
  settings        Json?                         // non-secret settings (from address, phone id…)
  status          String   @default("idle")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([tenantId, channel])
  @@index([tenantId])
}

model ChannelMessage {
  id             String   @id @default(cuid())
  tenantId       String
  channel        String
  direction      String                          // inbound | outbound
  senderId       String   @default("")
  recipientId    String   @default("")
  threadId       String   @default("")
  text           String   @default("")
  media          Json?
  raw            Json?
  messageId      String   @default("")
  idempotencyKey String   @default("")
  sent           Boolean  @default(false)
  dryRun         Boolean  @default(true)
  createdAt      DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, channel])
  @@index([tenantId, idempotencyKey])
}

model ChannelConsent {
  id        String   @id @default(cuid())
  tenantId  String
  channel   String
  contact   String                               // phone/email/handle the consent is for
  optedIn   Boolean  @default(false)
  scope     String   @default("all")             // all | marketing | transactional
  source    String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, channel, contact])
  @@index([tenantId])
}

model ChannelWebhookEvent {
  id        String   @id @default(cuid())
  tenantId  String
  channel   String
  raw       Json?
  processed Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, channel])
}

model PixieContact {
  id               String   @id @default(cuid())
  tenantId         String
  type             String   @default("email")    // email | phone | whatsapp | telegram | other
  valueRef         String?                        // token-vault ref, never plaintext
  valueMasked      String   @default("")
  verified         Boolean  @default(false)
  preferredChannel String   @default("email")
  notifyOn         Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([tenantId])
  @@index([tenantId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Pixie Lab — additive Prisma models for the authenticated Lab (feed, agents,
// entitlements). ADDITIVE ONLY: NEW models, nothing existing changed/renamed. NO
// migration run. Tenant-scoped (tenantId) per the multi-tenant rule. Auth itself
// is Supabase (not modeled here); `tenantId` derives from the Supabase user id.
// Until prisma-client-py / direct Postgres is approved, the Lab persists through
// the in-memory seam in backend/feed/store.py + backend/entitlements (same shapes).
// ─────────────────────────────────────────────────────────────────────────────

model BusinessProfile {
  id            String   @id @default(cuid())
  tenantId      String
  businessName  String   @default("")
  industry      String   @default("")
  whatTheySell  String   @default("")
  city          String   @default("")
  websiteUrl    String   @default("")
  socialLinks   String   @default("")
  contactChannel String  @default("")
  mainGoal      String   @default("")
  onboarded     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId])
  @@index([tenantId])
}

model AgentEntitlement {
  id             String   @id @default(cuid())
  tenantId       String
  agent          String                          // website | receptionist | seo | marketing | content
  state          String   @default("locked")     // locked | trial | active | expired
  plan           String   @default("")
  trialStartedAt DateTime?
  trialEndsAt    DateTime?
  activeStartedAt DateTime?
  cancelledAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([tenantId, agent])
  @@index([tenantId])
}

model FeedCard {
  id              String   @id @default(cuid())
  tenantId        String
  cardKey         String                          // stable rule id (e.g. r_leads_followup)
  heading         String                          // 5-6 words
  fullIdea        String   @default("")
  reason          String   @default("")
  category        String
  priority        String   @default("medium")
  primaryAgent    String
  supportingAgents Json?
  sourceSignals   Json?
  actions         Json?
  outcome         String   @default("")
  status          String   @default("new")        // new | viewed | approved | skipped | completed | expired
  createdAt       DateTime @default(now())
  expiresAt       DateTime?

  @@index([tenantId])
  @@index([tenantId, status])
}

model FeedFeedback {
  id           String   @id @default(cuid())
  tenantId     String
  cardKey      String
  feedbackType String                             // not_relevant | helpful | remind_later
  note         String   @default("")
  createdAt    DateTime @default(now())

  @@index([tenantId])
}

model ApprovalItem {
  id          String   @id @default(cuid())
  tenantId    String
  agent       String
  title       String
  description String   @default("")
  preview     Json?
  actionType  String
  payload     Json?
  status      String   @default("pending")        // pending | approved | rejected | executed | failed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, status])
}

model ActivityLog {
  id        String   @id @default(cuid())
  tenantId  String
  agent     String   @default("")
  type      String                                // feed_card_approved | trial_started | agent_unlocked | ...
  title     String   @default("")
  details   String   @default("")
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, type])
}
