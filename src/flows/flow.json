{
  "version": "7.0",
  "data_api_version": "3.0",
  "routing_model": {
    "COMMON": ["SALON", "DETAILS", "AGENT", "PNICHE"],
    "SALON": ["SERVICE"],
    "SERVICE": ["FINISH"],
    "AGENT": ["LISTING"],
    "LISTING": ["FINISH"],
    "DETAILS": ["FINISH", "HVAC_SERVICE"],
    "HVAC_SERVICE": ["FINISH"],
    "PNICHE": ["PORTFOLIO"],
    "PORTFOLIO": ["PEXP", "PROJECT", "PORTFOLIO_WORK"],
    "PEXP": ["PROJECT", "PORTFOLIO_WORK"],
    "PROJECT": ["PORTFOLIO_WORK"],
    "PORTFOLIO_WORK": ["FINISH", "PACKAGE"],
    "PACKAGE": ["FINISH"],
    "FINISH": []
  },
  "screens": [
    {
      "id": "COMMON",
      "title": "${data.common_title}",
      "data": {
        "common_title": { "type": "string", "__example__": "About your business" },
        "l_name": { "type": "string", "__example__": "Business name" },
        "l_your_name": { "type": "string", "__example__": "Your name" },
        "l_business_desc": { "type": "string", "__example__": "What does your business do?" },
        "business_desc_helper": { "type": "string", "__example__": "A sentence or two — what you offer and who for." },
        "l_industry": { "type": "string", "__example__": "What kind of business?" },
        "industry_options": {
          "type": "array",
          "items": { "type": "object", "properties": { "id": { "type": "string" }, "title": { "type": "string" } } },
          "__example__": [{ "id": "salon", "title": "Salon & Beauty" }, { "id": "general", "title": "Other" }]
        },
        "l_logo": { "type": "string", "__example__": "Your logo" },
        "l_logo_desc": { "type": "string", "__example__": "Upload it and I'll clean up the background. Skip if you don't have one." },
        "l_next": { "type": "string", "__example__": "Next" }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "f1",
            "children": [
              { "type": "RadioButtonsGroup", "name": "industry", "label": "${data.l_industry}", "data-source": "${data.industry_options}", "required": true },
              {
                "type": "If",
                "condition": "${form.industry} == 'portfolio'",
                "then": [
                  { "type": "TextInput", "name": "your_name", "label": "${data.l_your_name}", "input-type": "text", "required": true }
                ],
                "else": [
                  { "type": "TextInput", "name": "business_name", "label": "${data.l_name}", "input-type": "text", "required": true },
                  { "type": "TextArea", "name": "business_description", "label": "${data.l_business_desc}", "helper-text": "${data.business_desc_helper}", "required": false }
                ]
              },
              {
                "type": "PhotoPicker",
                "name": "logo",
                "label": "${data.l_logo}",
                "description": "${data.l_logo_desc}",
                "photo-source": "camera_gallery",
                "min-uploaded-photos": 0,
                "max-uploaded-photos": 1
              },
              {
                "type": "Footer",
                "label": "${data.l_next}",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": { "business_name": "${form.business_name}", "your_name": "${form.your_name}", "business_description": "${form.business_description}", "industry": "${form.industry}", "logo": "${form.logo}" }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "SALON",
      "title": "${data.salon_title}",
      "data": {
        "salon_title": { "type": "string", "__example__": "Salon details" },
        "l_currency": { "type": "string", "__example__": "Currency" },
        "currency_options": {
          "type": "array",
          "items": { "type": "object", "properties": { "id": { "type": "string" }, "title": { "type": "string" } } },
          "__example__": [{ "id": "USD", "title": "USD ($)" }, { "id": "EUR", "title": "EUR (€)" }]
        },
        "l_booking_heading": { "type": "string", "__example__": "Online booking" },
        "l_booking": { "type": "string", "__example__": "How should clients book?" },
        "booking_options": {
          "type": "array",
          "items": { "type": "object", "properties": { "id": { "type": "string" }, "title": { "type": "string" } } },
          "__example__": [{ "id": "build", "title": "Build online booking into my site" }, { "id": "own", "title": "I use my own tool (Fresha, Booksy…)" }]
        },
        "l_booking_link": { "type": "string", "__example__": "Your booking link" },
        "booking_link_helper": { "type": "string", "__example__": "Paste your Fresha, Booksy or Calendly link — or skip and add it later." },
        "l_hours": { "type": "string", "__example__": "Opening hours" },
        "hours_helper": { "type": "string", "__example__": "e.g. Tue-Sat 9-7" },
        "l_next": { "type": "string", "__example__": "Next" }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "f_salon",
            "children": [
              { "type": "Dropdown", "name": "currency", "label": "${data.l_currency}", "data-source": "${data.currency_options}", "required": true },
              { "type": "TextSubheading", "text": "${data.l_booking_heading}" },
              { "type": "RadioButtonsGroup", "name": "booking", "label": "${data.l_booking}", "data-source": "${data.booking_options}", "required": true },
              {
                "type": "If",
                "condition": "${form.booking} == 'own'",
                "then": [
                  { "type": "TextInput", "name": "booking_link", "input-type": "text", "label": "${data.l_booking_link}", "helper-text": "${data.booking_link_helper}", "required": false }
                ]
              },
              { "type": "TextInput", "name": "hours", "input-type": "text", "label": "${data.l_hours}", "helper-text": "${data.hours_helper}", "required": false },
              {
                "type": "Footer",
                "label": "${data.l_next}",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": { "currency": "${form.currency}", "booking": "${form.booking}", "booking_link": "${form.booking_link}", "hours": "${form.hours}" }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "SERVICE",
      "title": "${data.service_title}",
      "data": {
        "service_title": { "type": "string", "__example__": "Your services" },
        "service_required": { "type": "boolean", "__example__": true },
        "added_summary": { "type": "string", "__example__": "Added so far: Haircut" },
        "added_visible": { "type": "boolean", "__example__": false },
        "l_sname": { "type": "string", "__example__": "Service name" },
        "sname_helper": { "type": "string", "__example__": "e.g. Haircut" },
        "l_sprice": { "type": "string", "__example__": "Price" },
        "sprice_helper": { "type": "string", "__example__": "e.g. 25" },
        "l_sdur": { "type": "string", "__example__": "Duration" },
        "sdur_helper": { "type": "string", "__example__": "e.g. 30 min" },
        "l_addmore": { "type": "string", "__example__": "Add more?" },
        "addmore_options": {
          "type": "array",
          "items": { "type": "object", "properties": { "id": { "type": "string" }, "title": { "type": "string" } } },
          "__example__": [{ "id": "add", "title": "Add another service" }, { "id": "done", "title": "That's all" }]
        },
        "l_continue": { "type": "string", "__example__": "Continue" },
        "service_init": {
          "type": "object",
          "properties": { "sname": { "type": "string" }, "sprice": { "type": "string" }, "sdur": { "type": "string" }, "addmore": { "type": "string" } },
          "__example__": { "sname": "", "sprice": "", "sdur": "", "addmore": "" }
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          { "type": "TextBody", "text": "${data.added_summary}", "visible": "${data.added_visible}" },
          {
            "type": "Form",
            "name": "f_service",
            "init-values": "${data.service_init}",
            "children": [
              { "type": "TextInput", "name": "sname", "input-type": "text", "label": "${data.l_sname}", "helper-text": "${data.sname_helper}", "required": "${data.service_required}" },
              { "type": "TextInput", "name": "sprice", "input-type": "number", "label": "${data.l_sprice}", "helper-text": "${data.sprice_helper}", "required": false },
              { "type": "TextInput", "name": "sdur", "input-type": "text", "label": "${data.l_sdur}", "helper-text": "${data.sdur_helper}", "required": false },
              { "type": "RadioButtonsGroup", "name": "addmore", "label": "${data.l_addmore}", "data-source": "${data.addmore_options}", "required": false },
              {
                "type": "Footer",
                "label": "${data.l_continue}",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": { "sname": "${form.sname}", "sprice": "${form.sprice}", "sdur": "${form.sdur}", "addmore": "${form.addmore}" }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "PACKAGE",
      "title": "${data.package_title}",
      "data": {
        "package_title": { "type": "string", "__example__": "Your packages" },
        "package_required": { "type": "boolean", "__example__": true },
        "added_summary": { "type": "string", "__example__": "Added so far: Wedding Day" },
        "added_visible": { "type": "boolean", "__example__": false },
        "l_currency": { "type": "string", "__example__": "Currency" },
        "currency_options": {
          "type": "array",
          "items": { "type": "object", "properties": { "id": { "type": "string" }, "title": { "type": "string" } } },
          "__example__": [{ "id": "USD", "title": "USD ($)" }, { "id": "EUR", "title": "EUR (€)" }]
        },
        "currency_visible": { "type": "boolean", "__example__": true },
        "l_pkgname": { "type": "string", "__example__": "Package name" },
        "pkgname_helper": { "type": "string", "__example__": "e.g. Wedding Day" },
        "l_pkgprice": { "type": "string", "__example__": "Price" },
        "pkgprice_helper": { "type": "string", "__example__": "e.g. 3400" },
        "l_pkgdur": { "type": "string", "__example__": "Duration / coverage" },
        "pkgdur_helper": { "type": "string", "__example__": "e.g. 8 hours coverage" },
        "l_pkgincl": { "type": "string", "__example__": "What's included" },
        "pkgincl_helper": { "type": "string", "__example__": "One per line — e.g. 8-hour coverage, 500+ edited photos, online gallery" },
        "l_addmore": { "type": "string", "__example__": "Add more?" },
        "addmore_options": {
          "type": "array",
          "items": { "type": "object", "properties": { "id": { "type": "string" }, "title": { "type": "string" } } },
          "__example__": [{ "id": "add", "title": "Add another package" }, { "id": "done", "title": "That's all" }]
        },
        "l_continue": { "type": "string", "__example__": "Continue" },
        "package_init": {
          "type": "object",
          "properties": { "pkgname": { "type": "string" }, "pkgprice": { "type": "string" }, "pkgdur": { "type": "string" }, "pkgincl": { "type": "string" }, "addmore": { "type": "string" } },
          "__example__": { "pkgname": "", "pkgprice": "", "pkgdur": "", "pkgincl": "", "addmore": "" }
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          { "type": "TextBody", "text": "${data.added_summary}", "visible": "${data.added_visible}" },
          {
            "type": "Form",
            "name": "f_package",
            "init-values": "${data.package_init}",
            "children": [
              { "type": "Dropdown", "name": "currency", "label": "${data.l_currency}", "data-source": "${data.currency_options}", "visible": "${data.currency_visible}", "required": "${data.currency_visible}" },
              { "type": "TextInput", "name": "pkgname", "input-type": "text", "label": "${data.l_pkgname}", "helper-text": "${data.pkgname_helper}", "required": "${data.package_required}" },
              { "type": "TextInput", "name": "pkgprice", "input-type": "number", "label": "${data.l_pkgprice}", "helper-text": "${data.pkgprice_helper}", "required": false },
              { "type": "TextInput", "name": "pkgdur", "input-type": "text", "label": "${data.l_pkgdur}", "helper-text": "${data.pkgdur_helper}", "required": false },
              { "type": "TextArea", "name": "pkgincl", "label": "${data.l_pkgincl}", "helper-text": "${data.pkgincl_helper}", "required": false },
              { "type": "RadioButtonsGroup", "name": "addmore", "label": "${data.l_addmore}", "data-source": "${data.addmore_options}", "required": false },
              {
                "type": "Footer",
                "label": "${data.l_continue}",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": { "currency": "${form.currency}", "pkgname": "${form.pkgname}", "pkgprice": "${form.pkgprice}", "pkgdur": "${form.pkgdur}", "pkgincl": "${form.pkgincl}", "addmore": "${form.addmore}" }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "DETAILS",
      "title": "${data.details_title}",
      "data": {
        "details_title": { "type": "string", "__example__": "A few details" },
        "l_currency": { "type": "string", "__example__": "Currency" },
        "currency_options": {
          "type": "array",
          "items": { "type": "object", "properties": { "id": { "type": "string" }, "title": { "type": "string" } } },
          "__example__": [{ "id": "USD", "title": "USD ($)" }, { "id": "EUR", "title": "EUR (€)" }]
        },
        "currency_visible": { "type": "boolean", "__example__": false },
        "l_niche": { "type": "string", "__example__": "What kind of work do you do?" },
        "niche_options": {
          "type": "array",
          "items": { "type": "object", "properties": { "id": { "type": "string" }, "title": { "type": "string" } } },
          "__example__": [{ "id": "photographer", "title": "Photographer / Videographer" }, { "id": "designer", "title": "Designer / Creative" }]
        },
        "niche_visible": { "type": "boolean", "__example__": false },
        "portfolio_extra_visible": { "type": "boolean", "__example__": false },
        "l_skills": { "type": "string", "__example__": "Skills & tools" },
        "skills_helper": { "type": "string", "__example__": "" },
        "l_links": { "type": "string", "__example__": "Your links" },
        "links_helper": { "type": "string", "__example__": "" },
        "l_pyears": { "type": "string", "__example__": "Years of experience" },
        "pyears_helper": { "type": "string", "__example__": "" },
        "l_focus": { "type": "string", "__example__": "Currently working on" },
        "focus_helper": { "type": "string", "__example__": "" },
        "f1_label": { "type": "string", "__example__": "Tell us about your work" },
        "f1_helper": { "type": "string", "__example__": "" },
        "f2_label": { "type": "string", "__example__": "More" },
        "f2_helper": { "type": "string", "__example__": "" },
        "f2_visible": { "type": "boolean", "__example__": true },
        "l_next": { "type": "string", "__example__": "Next" }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "f_details",
            "children": [
              { "type": "Dropdown", "name": "currency", "label": "${data.l_currency}", "data-source": "${data.currency_options}", "visible": "${data.currency_visible}", "required": "${data.currency_visible}" },
              { "type": "Dropdown", "name": "portfolio_niche", "label": "${data.l_niche}", "data-source": "${data.niche_options}", "visible": "${data.niche_visible}", "required": "${data.niche_visible}" },
              { "type": "TextArea", "name": "f1", "label": "${data.f1_label}", "helper-text": "${data.f1_helper}", "required": false },
              { "type": "TextInput", "name": "p_skills", "input-type": "text", "label": "${data.l_skills}", "helper-text": "${data.skills_helper}", "required": false, "visible": "${data.portfolio_extra_visible}" },
              { "type": "TextInput", "name": "p_links", "input-type": "text", "label": "${data.l_links}", "helper-text": "${data.links_helper}", "required": false, "visible": "${data.portfolio_extra_visible}" },
              { "type": "TextInput", "name": "p_years", "input-type": "number", "label": "${data.l_pyears}", "helper-text": "${data.pyears_helper}", "required": false, "visible": "${data.portfolio_extra_visible}" },
              { "type": "TextInput", "name": "p_focus", "input-type": "text", "label": "${data.l_focus}", "helper-text": "${data.focus_helper}", "required": false, "visible": "${data.portfolio_extra_visible}" },
              { "type": "TextArea", "name": "f2", "label": "${data.f2_label}", "helper-text": "${data.f2_helper}", "required": false, "visible": "${data.f2_visible}" },
              {
                "type": "Footer",
                "label": "${data.l_next}",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": { "currency": "${form.currency}", "portfolio_niche": "${form.portfolio_niche}", "f1": "${form.f1}", "p_skills": "${form.p_skills}", "p_links": "${form.p_links}", "p_years": "${form.p_years}", "p_focus": "${form.p_focus}", "f2": "${form.f2}" }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "PNICHE",
      "title": "${data.pniche_title}",
      "data": {
        "pniche_title": { "type": "string", "__example__": "What do you do?" },
        "l_niche": { "type": "string", "__example__": "What kind of work do you do?" },
        "niche_options": {
          "type": "array",
          "items": { "type": "object", "properties": { "id": { "type": "string" }, "title": { "type": "string" } } },
          "__example__": [{ "id": "photographer", "title": "Photographer / Videographer" }, { "id": "developer", "title": "Developer / Engineer" }]
        },
        "l_next": { "type": "string", "__example__": "Next" }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "f_pniche",
            "children": [
              { "type": "RadioButtonsGroup", "name": "portfolio_niche", "label": "${data.l_niche}", "data-source": "${data.niche_options}", "required": true },
              {
                "type": "Footer",
                "label": "${data.l_next}",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": { "portfolio_niche": "${form.portfolio_niche}" }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "PORTFOLIO",
      "title": "${data.portfolio_title}",
      "data": {
        "portfolio_title": { "type": "string", "__example__": "Your work" },
        "l_about_photo": { "type": "string", "__example__": "A photo of you" },
        "about_photo_desc": { "type": "string", "__example__": "A headshot for your About section — optional." },
        "about_photo_visible": { "type": "boolean", "__example__": false },
        "l_bio": { "type": "string", "__example__": "Short bio" },
        "bio_helper": { "type": "string", "__example__": "A line about you. Or leave blank." },
        "l_skills": { "type": "string", "__example__": "Skills & tools" },
        "skills_helper": { "type": "string", "__example__": "" },
        "skills_visible": { "type": "boolean", "__example__": false },
        "l_pyears": { "type": "string", "__example__": "Years of experience" },
        "pyears_helper": { "type": "string", "__example__": "" },
        "years_visible": { "type": "boolean", "__example__": false },
        "l_focus": { "type": "string", "__example__": "Currently working on" },
        "focus_helper": { "type": "string", "__example__": "" },
        "focus_visible": { "type": "boolean", "__example__": false },
        "l_next": { "type": "string", "__example__": "Next" }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "f_portfolio",
            "children": [
              {
                "type": "PhotoPicker",
                "name": "about_photo",
                "label": "${data.l_about_photo}",
                "description": "${data.about_photo_desc}",
                "photo-source": "camera_gallery",
                "min-uploaded-photos": 0,
                "max-uploaded-photos": 1,
                "visible": "${data.about_photo_visible}"
              },
              { "type": "TextArea", "name": "f1", "label": "${data.l_bio}", "helper-text": "${data.bio_helper}", "required": false },
              { "type": "TextInput", "name": "p_skills", "input-type": "text", "label": "${data.l_skills}", "helper-text": "${data.skills_helper}", "required": false, "visible": "${data.skills_visible}" },
              { "type": "TextInput", "name": "p_years", "input-type": "number", "label": "${data.l_pyears}", "helper-text": "${data.pyears_helper}", "required": false, "visible": "${data.years_visible}" },
              { "type": "TextInput", "name": "p_focus", "input-type": "text", "label": "${data.l_focus}", "helper-text": "${data.focus_helper}", "required": false, "visible": "${data.focus_visible}" },
              {
                "type": "Footer",
                "label": "${data.l_next}",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": { "about_photo": "${form.about_photo}", "f1": "${form.f1}", "p_skills": "${form.p_skills}", "p_years": "${form.p_years}", "p_focus": "${form.p_focus}" }
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": "PORTFOLIO_WORK",
      "title": "${data.portfolio2_title}",
      "data": {
        "portfolio2_title": { "type": "string", "__example__": "Your work & links" },
        "l_photos": { "type": "string", "__example__": "Your work" },
        "photos_desc": { "type": "string", "__example__": "Upload a few of your best shots — up to 6. Or skip." },
        "photos_visible": { "type": "boolean", "__example__": false },
        "l_projects": { "type": "string", "__example__": "Projects to feature" },
        "projects_helper": { "type": "string", "__example__": "" },
        "projects_visible": { "type": "boolean", "__example__": false },
        "l_link1": { "type": "string", "__example__": "GitHub" },
        "link1_helper": { "type": "string", "__example__": "github.com/you — or just your username" },
        "link1_visible": { "type": "boolean", "__example__": true },
        "l_link2": { "type": "string", "__example__": "LinkedIn" },
        "link2_helper": { "type": "string", "__example__": "linkedin.com/in/you" },
        "link2_visible": { "type": "boolean", "__example__": true },
        "l_link3": { "type": "string", "__example__": "X / Twitter" },
        "link3_helper": { "type": "string", "__example__": "@handle" },
        "link3_visible": { "type": "boolean", "__example__": true },
        "l_link4": { "type": "string", "__example__": "Facebook" },
        "link4_helper": { "type": "string", "__example__": "facebook.com/yourpage" },
        "link4_visible": { "type": "boolean", "__example__": false },
        "l_next": { "type": "string", "__example__": "Next" }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "f_portfolio2",
            "children": [
              {
