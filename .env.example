# ──────────────────────────────────────────────
# WhatsApp Cloud API (Meta)
# ──────────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=your_permanent_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_waba_id
WEBHOOK_VERIFY_TOKEN=your_custom_verify_token
WHATSAPP_APP_SECRET=your_app_secret_for_signature_verification

# ──────────────────────────────────────────────
# Supabase (PostgreSQL + pgvector)
# ──────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# ──────────────────────────────────────────────
# LLM Provider
# ──────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key

# Open PageRank (free DA/PA authority dataset) — used by the landing /tools/da-pa-checker tool.
# Get a free key at https://www.domcop.com/openpagerank/ and set it in the landing deploy env.
OPEN_PAGERANK_API_KEY=replace-me-with-your-open-pagerank-api-key

# ──────────────────────────────────────────────
# Netlify (Website Preview Deployment)
# ──────────────────────────────────────────────
NETLIFY_TOKEN=your_netlify_personal_access_token

# ──────────────────────────────────────────────
# Stripe (Payments)
# ──────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key

# ──────────────────────────────────────────────
# Admin Dashboard
# ──────────────────────────────────────────────
ADMIN_PASSWORD=your_admin_password

# ──────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# ──────────────────────────────────────────────
# Website creation rate limit (per WhatsApp user)
# ──────────────────────────────────────────────
# Caps how many new preview websites a single non-tester, non-paid user can
# generate inside a rolling window. Tester phones (TESTER_PHONES) and users
# with any paid Stripe payment are exempt. Defaults: 5 sites per 24 hours.
WEBSITE_RATE_LIMIT_PER_DAY=5
WEBSITE_RATE_LIMIT_WINDOW_HOURS=24
